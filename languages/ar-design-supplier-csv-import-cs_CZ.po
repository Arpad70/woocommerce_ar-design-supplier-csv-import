msgid "The legacy wc-omega-connector plugin was deactivated automatically."
msgstr "Starý plugin wc-omega-connector byl automaticky deaktivován."

msgid "Supplier CSV Import"
msgstr "Import CSV dodavatele"

msgid "Configure CSV parsing, matching, field mapping, and WooCommerce-specific import behavior from this screen."
msgstr "Konfigurujte parsování CSV, párování, mapování polí a chování importu pro WooCommerce na této stránce."

msgid "Save settings"
msgstr "Uložit nastavení"

msgid "Run import now"
msgstr "Spustit import nyní"

msgid "Hourly"
msgstr "Hodinově"

msgid "Twice daily"
msgstr "Dvakrát denně"

msgid "Daily"
msgstr "Denně"

msgid "CSV source URL"
msgstr "URL zdroje CSV"

msgid "Import interval"
msgstr "Interval importu"

msgid "CSV delimiter"
msgstr "Oddělovač CSV"

msgid "CSV enclosure"
msgstr "Ohraničení CSV"

msgid "CSV contains header row"
msgstr "CSV obsahuje hlavičkový řádek"

msgid "Skip first rows"
msgstr "Přeskočit první řádky"

msgid "Match products by"
msgstr "Párovat produkty podle"

msgid "Import behavior"
msgstr "Chování importu"

msgid "Default product type"
msgstr "Výchozí typ produktu"

msgid "Field mapping"
msgstr "Mapování polí"

msgid "Category handling"
msgstr "Zpracování kategorií"

msgid "Import product attributes"
msgstr "Importovat atributy produktu"

msgid "Import product images"
msgstr "Importovat obrázky produktu"

msgid "Import stock data"
msgstr "Importovat stav zásob"

msgid "Supplier CSV settings"
msgstr "Nastavení importu CSV dodavatele"

msgid "Unauthorized request."
msgstr "Neautorizovaný požadavek."

msgid "Supplier CSV file is empty or invalid."
msgstr "Soubor CSV dodavatele je prázdný nebo neplatný."

msgid "Supplier CSV import completed: %d created, %d updated."
msgstr "Import CSV dokončen: %d vytvořeno, %d aktualizováno."

msgid "Supplier CSV import completed: no matching products found for the configured criteria."
msgstr "Import CSV dokončen: pro zadaná kritéria nebyly nalezeny žádné odpovídající produkty."

msgid "Supplier CSV import completed with no changes."
msgstr "Import CSV dokončen bez změn."

msgid "Unable to download CSV, HTTP %s."
msgstr "Nelze stáhnout CSV, HTTP %s."

msgid "Downloaded CSV is empty."
msgstr "Stažené CSV je prázdné."

msgid "Unable to write supplier CSV file."
msgstr "Nelze zapsat soubor CSV dodavatele."

msgid "Supplier CSV import has been started manually. Results will appear after the import finishes."
msgstr "Import CSV byl spuštěn ručně. Výsledky se zobrazí po dokončení importu."

msgid "AR Design Supplier CSV Import requires WooCommerce to be active."
msgstr "AR Design Supplier CSV Import vyžaduje aktivní WooCommerce."
